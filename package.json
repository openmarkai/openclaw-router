{
  "name": "openmark-router",
  "version": "7.1.4",
  "description": "Benchmark-driven model routing for OpenClaw. Uses your own benchmark data to route tasks to better-fit models and reduce overuse of expensive flagship models.",
  "license": "Apache-2.0",
  "author": "openmarkai",
  "homepage": "https://openmark.ai",
  "repository": "https://github.com/openmarkai/openclaw-router",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "providers": [
      "openmark"
    ],
    "compat": {
      "pluginApi": ">=2026.2.0",
      "minGatewayVersion": "2026.3.28"
    },
    "build": {
      "openclawVersion": "2026.3.28",
      "pluginSdkVersion": "2026.3.28"
    },
    "install": {
      "minHostVersion": ">=2026.3.28"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc --watch",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
